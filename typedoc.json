{
  "$schema": "https://typedoc.org/schema.json",

  "compilerOptions": {
    "skipLibCheck": true
  },

  "entryPoints": [
    "./src/lib/discriminator/index.ts",
    "./src/lib/number/index.ts",
    "./src/lib/palette/index.ts",
    "./src/lib/palette-color/index.ts",
    "./src/lib/sketch/index.ts",
    "./src/lib/string/index.ts"
  ],

  "out": "./_doc",

  "customCss": "./typedoc/style.css",

  "includeVersion": false,

  "navigationLinks": {
    "Sketches": "https://blwatkins.github.io/sketches/",
    "Brittni Watkins": "https://blwatkins.github.io/"
  },

  "navigation": {
    "includeCategories": true,
    "includeGroups": true,
    "includeFolders": true
  },

  "visibilityFilters": {
    "private": true,
    "protected": true,
    "inherited": true,
    "external": true,
    "@alpha": true,
    "@beta": true,
    "@deprecated": true
  },

  "sort": ["kind", "visibility", "static-first", "alphabetical", "enum-value-ascending"],

  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": true
  },

  "intentionallyNotDocumented": [
    "sketch.sketch.aspect_ratio.ASPECT_RATIO_CONFIG_SCHEMA.__type.DISCRIMINATOR.__type.I_ASPECT_RATIO_CONFIG",
    "palette-color.palette_color.PALETTE_COLOR_SCHEMA.__type.DISCRIMINATOR.__type.I_PALETTE_COLOR"
  ],

  "treatWarningsAsErrors": true,

  "customFooterHtml": "<br/>Copyright &copy; 2024-2026 Brittni Watkins."
}
