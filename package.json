{
  "name": "sketches",
  "license": "MIT",
  "private": true,
  "description": "Generative art sketches built using p5.js with shared utility classes for creative coding.",
  "author": {
    "name": "Brittni Watkins",
    "url": "https://blwatkins.github.io/"
  },
  "homepage": "https://github.com/blwatkins/sketches#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/blwatkins/sketches.git"
  },
  "bugs": {
    "url": "https://github.com/blwatkins/sketches/issues"
  },
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "docs": "typedoc",
    "lint:js": "eslint -c eslint.config.js.mjs .",
    "lint:ts": "eslint -c eslint.config.ts.mjs .",
    "lint:all": "npm run lint:js && npm run lint:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:check": "npm run build:dev && npm run build",
    "serve": "webpack-dev-server --mode production",
    "serve:dev": "webpack-dev-server --mode development"
  },
  "dependencies": {
    "p5": "^2.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "canvas": "^3.2.2",
    "css-loader": "^7.1.4",
    "eslint": "^10.1.0",
    "eslint-plugin-es-x": "^9.6.0",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.6",
    "jsdom": "^29.0.1",
    "mini-css-extract-plugin": "^2.10.2",
    "ts-loader": "^9.5.4",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
